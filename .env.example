# Telegram Bot Token (从 @BotFather 获取)
BOT_TOKEN=your_bot_token_here

# 管理员 Telegram ID (多个用逗号分隔)
ADMIN_IDS=123456789

# 推广链接
OFFICIAL_URL=https://your-official-site.com
APP_URL=https://your-app-download.com
MINI_APP_URL=https://t.me/your_bot/app
CS_URL=https://t.me/your_support_username
AGENT_URL=https://t.me/your_agent_username
GROUP_URL=https://t.me/your_group_link
CHANNEL_URL=https://t.me/your_channel_link

# 横幅图片 (URL 或 Telegram 文件ID)
BANNER_IMAGE=https://your-cdn.com/banner.jpg

# 密钥
SECRET_KEY=your-secret-key-here
